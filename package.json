{
  "name": "@codenameryuu/adonis-scheduler",
  "description": "A task scheduler for AdonisJS",
  "version": "1.0.1",
  "author": "codenameryuu",
  "license": "MIT",
  "homepage": "https://github.com/codenameryuu/adonis-scheduler#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codenameryuu/adonis-scheduler.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "files": [
    "build"
  ],
  "exports": {
    ".": "./build/index.js",
    "./services/main": "./build/services/main.js",
    "./scheduler_provider": "./build/providers/scheduler_provider.js",
    "./commands": "./build/commands/main.js"
  },
  "scripts": {
    "build": "npm run clean && npm run build-only && npm run copyfiles",
    "copyfiles": "copyfiles \"stubs/**/*.stub\" build",
    "build-only": "tsc && npm run index:commands",
    "clean": "rimraf build",
    "prepublishOnly": "npm run build",
    "index:commands": "adonis-kit index build/commands",
    "test": "node --enable-source-maps --import=ts-node-maintained/register/esm bin/test.ts"
  },
  "devDependencies": {
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/prettier-config": "^1.2.1",
    "@adonisjs/tsconfig": "^1.2.1",
    "@japa/assert": "^4.0.0",
    "@japa/runner": "^3.1.4",
    "@swc/core": "^1.3.102",
    "@types/async-lock": "^1.4.2",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.1",
    "@types/node-cron": "^3.0.7",
    "copyfiles": "^2.4.1",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "ts-node-maintained": "^10.9.4",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "async-lock": "^1.4.1",
    "chokidar": "^4.0.2",
    "cron-parser": "^5.0.4",
    "luxon": "^3.5.0",
    "node-cron": "^3.0.2",
    "string-width": "^7.2.0"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0"
  },
  "keywords": [
    "adonis",
    "scheduler"
  ],
  "prettier": "@adonisjs/prettier-config",
  "publishConfig": {
    "tag": "latest",
    "access": "public"
  },
  "main": "build/providers/scheduler_provider.js"
}
